# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Database (shared for all modules) ─────────────────────────────────────────
PGHOST=postgres
PGPORT=5432
PGUSER=postgres
PGPASSWORD=password
PGDATABASE=pynemonk_core

# ── JWT (used by pynemonk-core-auth module) ───────────────────────────────────
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d
