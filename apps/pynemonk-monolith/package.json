{
  "name": "pynemonk-monolith",
  "version": "1.0.0",
  "description": "Single-process host that composes all pynemonk service modules",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "migrate": "tsx scripts/migrate.ts",
    "seed": "tsx scripts/seed.ts",
    "test": "echo \"No tests in monolith shell\""
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "cors": "^2.8.6",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "pynemonk-core-accounting": "*",
    "pynemonk-core-auth": "*",
    "pynemonk-core-school": "*",
    "pynemonk-core-system": "*",
    "reflect-metadata": "^0.2.2",
    "tsx": "^4.15.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.16",
    "typescript": "^5.3.3"
  },
  "type": "module"
}
